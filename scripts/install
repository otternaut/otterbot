#!/usr/bin/env bash
#
# install — publish every skill in ./skills into the global config directory
# of each supported AI tool (Claude, Codex, Cursor).
#
# For each skill directory `skills/<name>/`, an entry is published at:
#   ~/.claude/skills/<name>  (symlink -> <repo>/skills/<name>)
#   ~/.codex/skills/<name>   (real copy of <repo>/skills/<name>)
#   ~/.cursor/skills/<name>  (real copy of <repo>/skills/<name>)
#
# Why the split: only Claude Code follows symlinks when it discovers skills, so
# it gets a symlink and picks up edits live. Codex and Cursor do NOT traverse
# symlinks during discovery — they need real directories — so those targets get
# a copy. Re-run this script (or `scripts/install --sync`) after editing a skill
# to refresh those copies.
#
# Target directories are created if missing. Re-running is safe (idempotent):
# stale/wrong entries are refreshed, correct ones are left alone, and real paths
# this script did not create are never clobbered — they are skipped with a
# warning. Copied skills carry a `.toolbox-managed` marker so refreshes only
# ever overwrite copies this script owns.
#
# No dependencies beyond bash + coreutils.
# Usage: ./scripts/install [--dry-run] [--sync] [-h]

set -euo pipefail

# --- resolve repo root from this script's own location -----------------------
# This script lives in <repo>/scripts, so the repo root is one level up.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SKILLS_SRC="$REPO_ROOT/skills"

# Marker file dropped into every copied skill so we can tell our copies apart
# from a real directory the user created (which we must never clobber).
MARKER=".toolbox-managed"

# --- destination roots + publish mode ----------------------------------------
# Each entry is "<path>|<mode>" where mode is `symlink` or `copy`. Claude Code
# follows symlinks (and benefits from live edits); Codex and Cursor do not, so
# they get real copies.
TARGETS=(
  "$HOME/.claude/skills|symlink"
  "$HOME/.codex/skills|copy"
  "$HOME/.cursor/skills|copy"
)

# --- options -----------------------------------------------------------------
DRY_RUN=0

usage() {
  cat <<EOF
install — publish this repo's skills into your AI tool folders.

Usage: ./scripts/install [options]

Options:
  --dry-run    Show what would happen without touching the filesystem.
  --sync       Alias for a normal run; re-copies edited skills into Codex/Cursor.
  -h, --help   Show this help.

Publish model:
  ~/.claude/skills   symlink (Claude Code follows links; edits apply live)
  ~/.codex/skills    copy    (Codex does not follow links; re-run to refresh)
  ~/.cursor/skills   copy    (Cursor does not follow links; re-run to refresh)

Skills are read from: $SKILLS_SRC
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1 ;;
    --sync)    : ;; # a normal run already refreshes copies; accepted for clarity
    -h|--help) usage; exit 0 ;;
    *) echo "install: unknown option '$1'" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

# --- colors (only when writing to a terminal) --------------------------------
if [ -t 1 ]; then
  C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_DIM=$'\033[2m'; C_RESET=$'\033[0m'
else
  C_GREEN=''; C_YELLOW=''; C_DIM=''; C_RESET=''
fi

# --- counters ----------------------------------------------------------------
n_created=0 n_refreshed=0 n_ok=0 n_skipped=0

# Present a $HOME-relative path for tidy output.
tilde() { case "$1" in "$HOME"/*) printf '~%s' "${1#"$HOME"}";; *) printf '%s' "$1";; esac; }

# link_one <src> <dest>
# Symlink policy: point <dest> at <src>, refreshing a stale link, never
# clobbering a real path.
link_one() {
  local src="$1" dest="$2" pretty
  pretty="$(tilde "$dest")"

  if [ -L "$dest" ]; then
    local current
    current="$(readlink "$dest")"
    if [ "$current" = "$src" ]; then
      printf '  %s= %s%s (ok)\n' "$C_DIM" "$pretty" "$C_RESET"
      n_ok=$((n_ok + 1))
      return
    fi
    if [ "$DRY_RUN" -eq 1 ]; then
      printf '  %s~ %s%s (would refresh -> %s)\n' "$C_YELLOW" "$pretty" "$C_RESET" "$src"
    else
      rm -f "$dest"
      ln -s "$src" "$dest"
      printf '  %s~ %s%s (refreshed)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    fi
    n_refreshed=$((n_refreshed + 1))
    return
  fi

  if [ -e "$dest" ]; then
    printf '  %s! %s%s (skipped: real path exists, not a symlink)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    n_skipped=$((n_skipped + 1))
    return
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    printf '  %s+ %s%s (would create -> %s)\n' "$C_GREEN" "$pretty" "$C_RESET" "$src"
  else
    ln -s "$src" "$dest"
    printf '  %s+ %s%s (created)\n' "$C_GREEN" "$pretty" "$C_RESET"
  fi
  n_created=$((n_created + 1))
}

# copy_dir <src> <dest>
# Copy the skill into place and stamp it with our marker. Assumes <dest> does
# not already exist (callers clear it first).
copy_dir() {
  local src="$1" dest="$2"
  cp -R "$src" "$dest"
  printf '%s' "$REPO_ROOT" > "$dest/$MARKER"
}

# copy_one <src> <dest>
# Copy policy: materialize <src> as a real directory at <dest>. Refresh our own
# copies (identified by the marker) when the source drifts; upgrade a leftover
# symlink from an older install; never clobber a real path we did not create.
copy_one() {
  local src="$1" dest="$2" pretty
  pretty="$(tilde "$dest")"

  # Leftover symlink from the old symlink-everywhere model — upgrade to a copy.
  if [ -L "$dest" ]; then
    if [ "$DRY_RUN" -eq 1 ]; then
      printf '  %s~ %s%s (would replace symlink with copy)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    else
      rm -f "$dest"
      copy_dir "$src" "$dest"
      printf '  %s~ %s%s (symlink -> copy)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    fi
    n_refreshed=$((n_refreshed + 1))
    return
  fi

  if [ -d "$dest" ]; then
    if [ ! -e "$dest/$MARKER" ]; then
      # A real directory we did not create — never clobber it.
      printf '  %s! %s%s (skipped: real dir exists, not managed by toolbox)\n' "$C_YELLOW" "$pretty" "$C_RESET"
      n_skipped=$((n_skipped + 1))
      return
    fi
    # One of our copies — refresh only if the source content drifted.
    if diff -rq --exclude="$MARKER" "$src" "$dest" >/dev/null 2>&1; then
      printf '  %s= %s%s (ok)\n' "$C_DIM" "$pretty" "$C_RESET"
      n_ok=$((n_ok + 1))
      return
    fi
    if [ "$DRY_RUN" -eq 1 ]; then
      printf '  %s~ %s%s (would refresh copy)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    else
      rm -rf "$dest"
      copy_dir "$src" "$dest"
      printf '  %s~ %s%s (refreshed)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    fi
    n_refreshed=$((n_refreshed + 1))
    return
  fi

  if [ -e "$dest" ]; then
    # A real file lives here — never clobber it.
    printf '  %s! %s%s (skipped: real path exists)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    n_skipped=$((n_skipped + 1))
    return
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    printf '  %s+ %s%s (would copy)\n' "$C_GREEN" "$pretty" "$C_RESET"
  else
    copy_dir "$src" "$dest"
    printf '  %s+ %s%s (copied)\n' "$C_GREEN" "$pretty" "$C_RESET"
  fi
  n_created=$((n_created + 1))
}

# publish_one <mode> <src> <dest>
publish_one() {
  case "$1" in
    symlink) link_one "$2" "$3" ;;
    copy)    copy_one "$2" "$3" ;;
    *) echo "install: unknown publish mode '$1'" >&2; exit 2 ;;
  esac
}

# --- discover skills ---------------------------------------------------------
if [ ! -d "$SKILLS_SRC" ]; then
  echo "install: no skills directory found at $SKILLS_SRC" >&2
  exit 1
fi

skills=()
for dir in "$SKILLS_SRC"/*/; do
  [ -d "$dir" ] || continue                 # nothing matched the glob
  name="$(basename "$dir")"
  if [ ! -f "$dir/SKILL.md" ]; then
    printf '%s! %s%s (skipped: no SKILL.md)\n' "$C_YELLOW" "$name" "$C_RESET"
    continue
  fi
  skills+=("$name")
done

if [ "${#skills[@]}" -eq 0 ]; then
  echo "install: no valid skills found in $SKILLS_SRC" >&2
  exit 1
fi

[ "$DRY_RUN" -eq 1 ] && echo "${C_DIM}(dry run — no changes will be made)${C_RESET}"
echo "Publishing ${#skills[@]} skill(s) from $(tilde "$SKILLS_SRC")"

# --- publish loop ------------------------------------------------------------
for entry in "${TARGETS[@]}"; do
  target="${entry%%|*}"
  mode="${entry##*|}"
  echo
  echo "→ $(tilde "$target") (${mode})"
  if [ "$DRY_RUN" -eq 0 ]; then
    mkdir -p "$target"
  fi
  for name in "${skills[@]}"; do
    publish_one "$mode" "$SKILLS_SRC/$name" "$target/$name"
  done
done

# --- cursor rules (for the cursor-agent CLI backend) -------------------------
# The Cursor Agent CLI (`cursor-agent`) — used when the "cursor" model is picked
# inside super.engineering / Superconductor — has no Agent Skills feature; it
# reads Cursor *rules* from a global ~/.cursor/rules/ instead. Mirror each skill
# into a rule so the same guidance loads on demand under that backend.
publish_cursor_rules() {
  local exporter="$SCRIPT_DIR/export-cursor-rules"
  [ -x "$exporter" ] || return 0
  echo
  echo "→ ~/.cursor/rules (cursor-agent CLI)"
  if [ "$DRY_RUN" -eq 1 ]; then
    "$exporter" --dry-run | sed -n '/^  /p'
  else
    "$exporter" | sed -n '/^  /p'
  fi
}

publish_cursor_rules

# --- git hooks ---------------------------------------------------------------
# Point this repo's git at .githooks so the pre-commit hook keeps README.md's
# skills table in sync automatically. Only meaningful inside the repo's own
# git checkout; harmless to skip otherwise.
setup_git_hooks() {
  local hooks_dir="$REPO_ROOT/.githooks"
  [ -d "$hooks_dir" ] || return 0
  git -C "$REPO_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0

  echo
  echo "→ git hooks"
  local current
  current="$(git -C "$REPO_ROOT" config --local --get core.hooksPath 2>/dev/null || true)"
  if [ "$current" = ".githooks" ]; then
    printf '  %s= core.hooksPath already set to .githooks (ok)%s\n' "$C_DIM" "$C_RESET"
    return 0
  fi
  if [ "$DRY_RUN" -eq 1 ]; then
    printf '  %s~ would set core.hooksPath -> .githooks%s\n' "$C_YELLOW" "$C_RESET"
  else
    git -C "$REPO_ROOT" config --local core.hooksPath .githooks
    printf '  %s+ core.hooksPath set to .githooks%s\n' "$C_GREEN" "$C_RESET"
  fi
}

setup_git_hooks

# --- summary -----------------------------------------------------------------
echo
printf 'Done: %d created, %d refreshed, %d unchanged, %d skipped.\n' \
  "$n_created" "$n_refreshed" "$n_ok" "$n_skipped"

if [ "$n_created" -gt 0 ] || [ "$n_refreshed" -gt 0 ]; then
  echo "${C_DIM}Restart Codex and Cursor (and any super.engineering session using them) to pick up changes.${C_RESET}"
fi
