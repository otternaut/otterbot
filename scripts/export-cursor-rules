#!/usr/bin/env bash
#
# export-cursor-rules — generate a Cursor *rule* from every skill's SKILL.md and
# install it globally at ~/.cursor/rules/<name>.mdc.
#
# Why this exists: the Cursor Agent CLI (`cursor-agent`) — which is what runs
# when you pick the "cursor" model inside super.engineering / Superconductor —
# has no Agent Skills feature. It reads Cursor *rules* (`.cursor/rules/*.mdc`)
# instead, and it *does* read a global `~/.cursor/rules/` directory (verified).
# So we mirror each skill into a global rule, letting the same instructions load
# on demand under the cursor-agent backend. (The Cursor app and Codex use the
# real skill copies from scripts/install; Claude Code uses the symlink.)
#
# Each rule is written with `alwaysApply: false` and the skill's `description`,
# so cursor-agent loads it on demand by matching the request against the
# description — the same trigger model skills use, without bloating context.
#
# Rules are generated artifacts (a transform of SKILL.md), so re-run this after
# editing a skill. scripts/install calls it for you.
#
# Idempotent and non-destructive: it only refreshes rules it generated (tagged
# with a marker comment); a hand-written .mdc it did not create is left alone.
#
# No dependencies beyond bash + coreutils. Usage: ./scripts/export-cursor-rules [--dry-run] [-h]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SKILLS_SRC="$REPO_ROOT/skills"
RULES_DEST="$HOME/.cursor/rules"
SKILLS_COPY="$HOME/.cursor/skills"   # where scripts/install put supporting files

# Marker that identifies a rule this script generated, so refreshes never
# clobber a rule the user wrote by hand.
MARKER="toolbox-generated-rule"

DRY_RUN=0

usage() {
  cat <<EOF
export-cursor-rules — mirror each skill into a global Cursor rule for cursor-agent.

Usage: ./scripts/export-cursor-rules [options]

Options:
  --dry-run    Show what would happen without touching the filesystem.
  -h, --help   Show this help.

Skills are read from: $SKILLS_SRC
Rules are written to: $RULES_DEST/<name>.mdc
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "export-cursor-rules: unknown option '$1'" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

if [ -t 1 ]; then
  C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_DIM=$'\033[2m'; C_RESET=$'\033[0m'
else
  C_GREEN=''; C_YELLOW=''; C_DIM=''; C_RESET=''
fi

n_created=0 n_refreshed=0 n_ok=0 n_skipped=0

tilde() { case "$1" in "$HOME"/*) printf '~%s' "${1#"$HOME"}";; *) printf '%s' "$1";; esac; }

# frontmatter_description <skill.md>
# Print the skill's `description:` value (assumed a single physical line, which
# is the house style for SKILL.md).
frontmatter_description() {
  awk '
    NR==1 && $0=="---" { infm=1; next }
    infm && $0=="---"  { exit }
    infm && /^description:[[:space:]]*/ {
      sub(/^description:[[:space:]]*/, "")
      print
      exit
    }
  ' "$1"
}

# skill_body <skill.md>
# Print everything after the closing frontmatter fence.
skill_body() {
  awk '
    NR==1 && $0=="---" { seen=1; next }
    seen==1 && $0=="---" { seen=2; next }
    seen==2 { print }
  ' "$1"
}

# render_rule <name> <skill.md>  -> stdout
# Emit the full .mdc contents for a skill.
render_rule() {
  local name="$1" src="$2" desc
  desc="$(frontmatter_description "$src")"

  # Folded block scalar (>-) keeps the description a single logical line without
  # us having to quote/escape colons or quotes it may contain.
  printf -- '---\n'
  printf -- 'description: >-\n  %s\n' "$desc"
  printf -- 'alwaysApply: false\n'
  printf -- '---\n'
  printf -- '<!-- %s: %s — generated from skills/%s/SKILL.md by scripts/export-cursor-rules. Do not edit by hand. -->\n\n' \
    "$MARKER" "$name" "$name"
  printf -- '> This rule mirrors the `%s` Agent Skill for the Cursor CLI (cursor-agent),\n' "$name"
  printf -- '> which reads rules rather than skills. Supporting files referenced below\n'
  printf -- '> (e.g. `references/…`) live at `%s/%s/`.\n\n' "$(tilde "$SKILLS_COPY")" "$name"
  skill_body "$src"
}

is_ours() { grep -q "$MARKER" "$1" 2>/dev/null; }

# publish_rule <name> <skill.md>
publish_rule() {
  local name="$1" src="$2" dest pretty tmp
  dest="$RULES_DEST/$name.mdc"
  pretty="$(tilde "$dest")"

  if [ -e "$dest" ] && ! is_ours "$dest"; then
    printf '  %s! %s%s (skipped: rule exists, not generated by toolbox)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    n_skipped=$((n_skipped + 1))
    return
  fi

  tmp="$(render_rule "$name" "$src")"

  if [ -f "$dest" ]; then
    if [ "$tmp" = "$(cat "$dest")" ]; then
      printf '  %s= %s%s (ok)\n' "$C_DIM" "$pretty" "$C_RESET"
      n_ok=$((n_ok + 1))
      return
    fi
    if [ "$DRY_RUN" -eq 1 ]; then
      printf '  %s~ %s%s (would refresh)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    else
      printf '%s' "$tmp" > "$dest"
      printf '  %s~ %s%s (refreshed)\n' "$C_YELLOW" "$pretty" "$C_RESET"
    fi
    n_refreshed=$((n_refreshed + 1))
    return
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    printf '  %s+ %s%s (would create)\n' "$C_GREEN" "$pretty" "$C_RESET"
  else
    printf '%s' "$tmp" > "$dest"
    printf '  %s+ %s%s (created)\n' "$C_GREEN" "$pretty" "$C_RESET"
  fi
  n_created=$((n_created + 1))
}

if [ ! -d "$SKILLS_SRC" ]; then
  echo "export-cursor-rules: no skills directory found at $SKILLS_SRC" >&2
  exit 1
fi

skills=()
for dir in "$SKILLS_SRC"/*/; do
  [ -d "$dir" ] || continue
  name="$(basename "$dir")"
  [ -f "$dir/SKILL.md" ] || continue
  skills+=("$name")
done

if [ "${#skills[@]}" -eq 0 ]; then
  echo "export-cursor-rules: no valid skills found in $SKILLS_SRC" >&2
  exit 1
fi

[ "$DRY_RUN" -eq 1 ] && echo "${C_DIM}(dry run — no changes will be made)${C_RESET}"
echo "Exporting ${#skills[@]} skill(s) as Cursor rules"
echo "→ $(tilde "$RULES_DEST")"
[ "$DRY_RUN" -eq 0 ] && mkdir -p "$RULES_DEST"

for name in "${skills[@]}"; do
  publish_rule "$name" "$SKILLS_SRC/$name/SKILL.md"
done

echo
printf 'Done: %d created, %d refreshed, %d unchanged, %d skipped.\n' \
  "$n_created" "$n_refreshed" "$n_ok" "$n_skipped"
